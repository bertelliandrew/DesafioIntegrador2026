// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          Int          @id @default(autoincrement())
  nome        String
  email       String       @unique
  cidade      String
  estado      String
  pais        String
  criadoEm   DateTime     @default(now()) @map("criado_em")
  assinaturas Assinatura[]

  @@map("clientes")
}

model Plano {
  id                 Int          @id @default(autoincrement())
  nome               String
  descricao          String
  precoMensal        Float        @map("preco_mensal")
  limiteDispositivos Int          @map("limite_dispositivos")
  suporte            String
  recursos           String       // JSON serializado: ["item1","item2"]
  criadoEm          DateTime     @default(now()) @map("criado_em")
  assinaturas        Assinatura[]

  @@map("planos")
}

model Assinatura {
  id                  Int       @id @default(autoincrement())
  clienteId           Int       @map("cliente_id")
  planoId             Int       @map("plano_id")
  quantidadeFirewalls Int       @map("quantidade_firewalls")
  ciclo               String    @default("mensal")
  status              String    @default("ativa")
  valorMensal         Float     @map("valor_mensal")
  motivoCancelamento  String?   @map("motivo_cancelamento")
  criadoEm           DateTime  @default(now()) @map("criado_em")
  canceladoEm        DateTime? @map("cancelado_em")

  cliente Cliente @relation(fields: [clienteId], references: [id])
  plano   Plano   @relation(fields: [planoId], references: [id])

  @@map("assinaturas")
}
